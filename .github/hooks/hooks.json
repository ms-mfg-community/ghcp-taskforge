{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./scripts/hooks/session-start.sh",
        "powershell": "./scripts/hooks/session-start.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./scripts/hooks/session-end.sh",
        "powershell": "./scripts/hooks/session-end.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./scripts/hooks/log-prompt.sh",
        "powershell": "./scripts/hooks/log-prompt.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./scripts/hooks/security-check.sh",
        "powershell": "./scripts/hooks/security-check.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./scripts/hooks/post-tool-log.sh",
        "powershell": "./scripts/hooks/post-tool-log.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "./scripts/hooks/error-handler.sh",
        "powershell": "./scripts/hooks/error-handler.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
